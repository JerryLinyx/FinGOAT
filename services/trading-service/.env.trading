# TradingAgents Microservice Configuration

# Service Configuration
TRADING_SERVICE_PORT=8001
TRADING_SERVICE_HOST=0.0.0.0
REDIS_ADDR=localhost:6379
REDIS_DB=0

# OpenAI API (required for TradingAgents)
OPENAI_API_KEY=your_openai_api_key_here

# Alpha Vantage API (required for fundamental and news data)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Additional LLM providers (optional)
CLAUDE_API_KEY=your_claude_api_key
GEMINI_API_KEY=your_gemini_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
DASHSCOPE_API_KEY=your_dashscope_api_key

# LLM routing defaults (can be overridden per request/front-end)
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_QUICK_MODEL=gemma3:1b
LLM_DEEP_MODEL=gemma3:1b
LLM_TIMEOUT=120
LLM_TEMPERATURE=0.2
OPENAI_TOOL_MODEL=gpt-4o-mini
EMBED_MODEL=nomic-embed-text
EMBED_BASE_URL=http://localhost:11434/v1
# EMBED_API_KEY falls back to OLLAMA_API_KEY and defaults to "ollama"
#
# For DashScope defaults, use:
# LLM_PROVIDER=dashscope
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_QUICK_MODEL=qwen3.5-flash
# LLM_DEEP_MODEL=qwen3.5-flash
# DASHSCOPE_EMBED_MODEL=text-embedding-v4
# DASHSCOPE_EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_EMBED_API_KEY falls back to DASHSCOPE_API_KEY when provider=dashscope

# Service Settings
DEBUG=true
LOG_LEVEL=INFO

# CORS Settings
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
